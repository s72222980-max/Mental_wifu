{
    "name": "Venatrix Music",
    "description": "A Telegram Music Player Bot, written in Python with Pyrogram and Py-Tgcalls.",
    "logo": "https://files.catbox.moe/ah5y0f.jpeg",
    "keywords": [
        "python3",
        "telegram",
        "bot",
        "VENATRIX",
        "MusicBot",
        "telegram-bot",
        "pyrogram"
    ],
    "env": {
        "API_ID": {
            "description": "Get this value from https://my.telegram.org",
            "value": "",
            "required": true
        },
        "API_HASH": {
            "description": "Get this value from https://my.telegram.org",
            "value": "",
            "required": true
        },
        "BOT_TOKEN": {
            "description": "A Bot's token from Botfather",
            "value": "",
            "required": true
        },
        "MONGO_DB_URI": {
            "description": "Get a mongodb url from https://cloud.mongodb.com.",
            "value": "",
            "required": true
        },
        "OWNER_ID": {
            "description": "The user id of user whom you would like to add as OWNER.",
            "value": "",
            "required": true
        },
        "STRING_SESSION": {
            "description": "A Pyrogram v2 String Session from @STRINGSEASO_NBOT on Telegram.",
            "value": "",
            "required": true
        },
        "LOGGER_ID": {
            "description": "Your Log Group ID, add your bot and promote as an admin with full rights!",
            "value": "",
            "required": true
        },
        "HEROKU_API_KEY": {
            "description": "Your Heroku account's API key",
            "value": "",
            "required": false
        },
        "HEROKU_APP_NAME": {
            "description": "Your Heroku app name",
            "value": "",
            "required": false
        },
        "BOT_NAME": {
            "description": "Name of your bot",
            "value": "VENATRIX MUSIC",
            "required": false
        },
        "BOT_USERNAME": {
            "description": "Username of your bot (without @)",
            "value": "",
            "required": false
        },
        "OWNER_USERNAME": {
            "description": "Your Telegram username (without @)",
            "value": "",
            "required": false
        },
        "SUPPORT_CHANNEL": {
            "description": "Your support channel link (must start with https://)",
            "value": "https://t.me/",
            "required": false
        },
        "SUPPORT_CHAT": {
            "description": "Your support group link (must start with https://)",
            "value": "https://t.me/",
            "required": false
        }
    },
    "buildpacks": [
        {
            "url": "heroku/python"
        },
        {
            "url": "heroku/nodejs"
        },
        {
            "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest.git"
        }
    ],
    "stack": "container"
}
